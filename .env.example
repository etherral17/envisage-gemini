# Backend secrets
# Use a long random value in production.
SECRET_KEY=change-me

# Optional: supply a stable Fernet key (base64) instead of persisting in the Docker volume
# If unset, the backend will create/persist /app/data/fernet.key in the volume.
# FERNET_KEY=

# CORS (mainly for local dev if you hit backend directly)
CORS_ORIGINS=http://localhost:5173

# Backend dev-only endpoints (/keys, /waf/enable, /waf/disable)
# Keep OFF in production unless you explicitly need them.
# ENABLE_DEV_ENDPOINTS=1

# Frontend build-time API base (nginx proxies /api -> backend)
VITE_API_BASE_URL=/api

# Streamlit hackingtool default backend URL
BACKEND_BASE_URL=http://backend:5000
